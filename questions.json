<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>試験対策アプリ</title>
<style>
body { font-family: sans-serif; padding: 20px; }
button { margin: 5px; padding: 5px 10px; }
select { margin: 5px 0; padding: 5px; }
.correct { color: green; font-weight: bold; }
.wrong { color: red; font-weight: bold; }
</style>
</head>
<body>

<h1>試験対策アプリ</h1>

<div id="categoryArea"></div>
<hr>
<div id="questionArea"></div>
<div id="answersArea"></div>
<div id="explanationArea"></div>
<br>
<button onclick="nextQuestion()">次の問題</button>

<script>

let questions = [];
let filteredQuestions = [];
let currentIndex = 0;

fetch("questions.json")
  .then(response => response.json())
  .then(data => {
    questions = data;
    loadCategories();
  });

function loadCategories() {
  const categoryArea = document.getElementById("categoryArea");
  const categories = [...new Set(questions.map(q => q.category))];

  categories.forEach(cat => {
    const btn = document.createElement("button");
    btn.textContent = cat;
    btn.onclick = () => {
      filteredQuestions = questions.filter(q => q.category === cat);
      currentIndex = 0;
      showQuestion();
    };
    categoryArea.appendChild(btn);
  });
}

function showQuestion() {

  const q = filteredQuestions[currentIndex];
  if (!q) return;

  const questionDiv = document.getElementById("questionArea");
  const answersDiv = document.getElementById("answersArea");
  const explanationDiv = document.getElementById("explanationArea");

  questionDiv.innerHTML = `<h3>${q.question}</h3>`;
  answersDiv.innerHTML = "";
  explanationDiv.innerHTML = "";

  // ○×問題
  if (q.type === "truefalse") {
    ["○", "×"].forEach((label, index) => {
      const btn = document.createElement("button");
      btn.textContent = label;
      btn.onclick = () => {
        const userAnswer = index === 0;
        showResult(userAnswer === q.answer);
        explanationDiv.textContent = q.explanation;
      };
      answersDiv.appendChild(btn);
    });
  }

  // 多択問題
  if (q.type === "multiple") {
    q.choices.forEach((choice, index) => {
      const btn = document.createElement("button");
      btn.textContent = choice;
      btn.onclick = () => {
        showResult(index === q.answer);
        explanationDiv.textContent = q.explanation;
      };
      answersDiv.appendChild(btn);
    });
  }

  // 🔥 5空欄問題（個別判定）
  if (q.type === "multi_blank") {

    let selectedAnswers = new Array(q.answers.length).fill(null);
    let resultSpans = [];

    q.answers.forEach((correctVal, index) => {

      const row = document.createElement("div");

      const label = document.createElement("span");
      label.textContent = `空欄${index+1} `;
      row.appendChild(label);

      const select = document.createElement("select");
      select.innerHTML =
        `<option value="">選択してください</option>` +
        q.choices.map((choice, i) =>
          `<option value="${i}">${choice}</option>`
        ).join("");

      select.onchange = function () {
        selectedAnswers[index] = parseInt(this.value);
      };

      row.appendChild(select);

      const resultSpan = document.createElement("span");
      resultSpan.style.marginLeft = "10px";
      row.appendChild(resultSpan);

      resultSpans.push(resultSpan);

      answersDiv.appendChild(row);
    });

    const checkBtn = document.createElement("button");
    checkBtn.textContent = "解答";
    checkBtn.onclick = function () {

      q.answers.forEach((correctVal, i) => {
        if (selectedAnswers[i] === correctVal) {
          resultSpans[i].textContent = " ⭕";
          resultSpans[i].className = "correct";
        } else {
          resultSpans[i].textContent =
            " ❌ 正解: " + q.choices[correctVal];
          resultSpans[i].className = "wrong";
        }
      });

      explanationDiv.textContent = q.explanation;
    };

    answersDiv.appendChild(document.createElement("br"));
    answersDiv.appendChild(checkBtn);
  }
}

function showResult(isCorrect) {
  const result = document.createElement("div");
  result.innerHTML = isCorrect
    ? '<span class="correct">⭕ 正解！</span>'
    : '<span class="wrong">❌ 不正解</span>';
  document.getElementById("answersArea").appendChild(result);
}

function nextQuestion() {
  currentIndex++;
  if (currentIndex >= filteredQuestions.length) {
    currentIndex = 0;
  }
  showQuestion();
}

</script>

</body>
</html>
